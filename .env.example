# ─── MySQL Database (Hostinger) ──────────────────────────────────────────
# Create a MySQL database in your Hostinger control panel and fill these in.
# Without these, the app falls back to local JSON files (development only).
DB_HOST=localhost
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=your_database_name

# ─── Site URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── Meta Pixel ──────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id_here

# ─── Upload Directory (Hostinger only) ───────────────────────────────────
# Point this to public_html/images on the server so Apache can serve
# uploaded images directly. Leave unset for local development.
# UPLOAD_DIR=/home/username/domains/yourdomain/public_html/images
